# Ignore everything by default — whitelist only what we want
/*

# Tracked configs
!fish/
!nvim/
!wezterm/
!zed/
!.gitignore

# iTerm2 settings — only the plist (skip the AppSupport symlink + sockets dir)
!iterm2/
iterm2/*
!iterm2/com.googlecode.iterm2.plist

# Auto-commit helper script + its launchd agent
!scripts/
!launchd/

# Machine-specific fish state (not portable)
fish/fish_variables

# Zed prompt-library LMDB store — binary + a constantly-churning lock file.
# Can't be merged across machines; would generate endless noise commits.
zed/prompts/**/*.mdb

# fswatch smoke test
