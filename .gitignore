# Ignore everything by default — whitelist only what we want
/*

# Tracked configs
!fish/
!nvim/
!wezterm/
!.gitignore

# iTerm2 settings — only the plist (skip the AppSupport symlink + sockets dir)
!iterm2/
iterm2/*
!iterm2/com.googlecode.iterm2.plist

# Auto-commit helper script + its launchd agent
!scripts/
!launchd/

# Machine-specific fish state (not portable)
fish/fish_variables
